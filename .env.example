# Copiar este archivo como .env y completar los valores reales

# MercadoPago
MP_ACCESS_TOKEN=APP_USR-tu_access_token_aqui

# URL pública del servidor donde MP enviará el webhook
# En desarrollo: usar ngrok → https://xxxx.ngrok.io
WEBHOOK_URL=https://tu-dominio.com/mercadopago-webhook

# URL del frontend (para back_urls de MP)
APP_URL=https://tu-dominio.com

# UltraMsg (WhatsApp)
ULTRAMSG_INSTANCE=instanceXXXX
ULTRAMSG_TOKEN=tu_token_aqui
